{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/translate.py",
      "use": "@vercel/python@4.5.0",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/health.py",
      "use": "@vercel/python@4.5.0"
    }
  ],
  "routes": [
    { "src": "/api/translate", "dest": "api/translate.py", "methods": ["POST", "OPTIONS"] },
    { "src": "/api/health", "dest": "api/health.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
